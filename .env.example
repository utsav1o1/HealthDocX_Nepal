# HealthDocX - Environment Variables Example
# Copy this file to .env.local and fill in your values for local development
# Use these keys in your Vercel Environment Variables settings

# MongoDB Atlas Connection
MONGODB_URI=

# NextAuth Configuration
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Gemini AI
GEMINI_API_KEY=
